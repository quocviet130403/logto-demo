# ===== Domain =====
DOMAIN=logto-demo.minproxy.io
DOMAIN_AUTH=logto-demo-auth.minproxy.io
DOMAIN_ADMIN=logto-demo-admin.minproxy.io
DOMAIN_MAIL=logto-demo-mail.minproxy.io
ACME_EMAIL=your-email@example.com

# ===== Logto =====
LOGTO_ENDPOINT=https://logto-demo-auth.minproxy.io
LOGTO_ADMIN_ENDPOINT=https://logto-demo-admin.minproxy.io

# ===== Database =====
POSTGRES_USER=logto
POSTGRES_PASSWORD=logto_password
POSTGRES_DB=logto

# ===== Mailpit =====
MAILPIT_SMTP_HOST=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_UI=https://logto-demo-mail.minproxy.io

# ===== Frontend (Next.js) =====
# Fill these after creating an application in Logto Admin Console
LOGTO_APP_ID=your-app-id
LOGTO_APP_SECRET=your-app-secret
LOGTO_COOKIE_SECRET=complex_password_at_least_32_characters_long_change_me
NEXT_PUBLIC_BASE_URL=https://logto-demo.minproxy.io

# ===== Backend (NestJS) =====
# Fill this after creating an API Resource in Logto Admin Console
LOGTO_API_RESOURCE=https://logto-demo.minproxy.io/api
